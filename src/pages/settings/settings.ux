<template>
  <div class="page">
    <scroll scroll-y="true" class="page-scroll">
      <div class="container">
        
        <div class="header">
          <text class="back" @click="goBack">返回</text>
          <text class="header-time">{{ currentTime }}</text>
          <text class="title">系统设置</text>
        </div>

        <div class="settings-card">
          <text class="card-title">清除数据</text>
          <text class="card-desc">清除所有统计和进度。</text>
          <div class="action-btn danger-style" @click="startClearConfirmation">
            <text class="action-txt">清空数据</text>
          </div>
        </div>

        <div class="settings-card">
          <div class="row-item">
            <text class="switch-label">屏幕常亮</text>
            <switch class="small-switch" checked="{{ keepScreenOn }}" @change="onKeepScreenOnChange"></switch>
          </div>
          <text class="card-desc">开启后，屏幕将保持常亮状态。</text>
        </div>

        <div class="info-card">
          <text class="info-header">详细信息</text>
          <text class="sub-text">机型: 小米手环 9 Pro</text>
          <text class="sub-text">版本号v1.0.0</text>
        </div>

      </div>
    </scroll>
  </div>
</template>

<style>
  .page {
    width: 100%;
    height: 100%;
    flex-direction: column;
    background-color: #000000;
  }
  .page-scroll {
    width: 100%;
    flex-direction: column;
