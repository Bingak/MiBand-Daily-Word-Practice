    padding: 5px 10px;
  }

  .title {
    font-size: 24px;
    color: #ffffff;
    font-weight: bold;
  }

  .settings-card {
    width: 100%;
    background-color: #1a1a1a;
    border-radius: 14px;
    padding: 20px;
    flex-direction: column;
    margin-bottom: 20px;
  }

  .card-title {
    font-size: 24px;
    color: #ffffff;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .card-desc {
    font-size: 18px;
    color: #95a5a6;
    line-height: 26px;
    margin-top: 8px;
  }

  .action-btn {
    width: 100%;
    height: 75px;
    justify-content: center;
    align-items: center;
    border-radius: 12px;
    margin-top: 6px;
  }

  .danger-style {
    background-color: #e74c3c;
  }

