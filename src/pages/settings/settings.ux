    font-weight: bold;
  }

  .row-item {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }
  .small-switch {
    width: 60px;
    height: 34px;
  }
  .switch-label {
    font-size: 24px;
    color: #ffffff;
    font-weight: bold;
  }
  .small-switch {
  /* 缩小到原来的 0.75 倍 */
  transform: scale(0.75); 
  transform-origin: center right; 
}

  /* ========== 信息卡片 ========== */
  .info-card {
    width: 100%;
    background-color: #1a1a1a;
    border-radius: 14px;
    padding: 20px;
    flex-direction: column;
    margin-bottom: 10px;
  }

  .info-header {
    font-size: 21px;
    color: #aaaaaa;
    margin-bottom: 10px;
  }

  .sub-text {
    font-size: 18px;
    color: #7f8c8d;
    margin-bottom: 4px;
  }
</style>

<script>
  import router from '@system.router';
  import storage from '@system.storage';
  import prompt from '@system.prompt';
  import brightness from '@system.brightness';

  export default {
  
    private: {
      currentTime: '00:00', 
      timer: null,
      keepScreenOn: false,
    },
  onReady() {
    this.updateTime();          // 立即显示一次
    this.timer = setInterval(() => {
      this.updateTime();
    }, 1000);                   // 每秒刷新
  },
  onHide() {
    if (this.timer) {
      clearInterval(this.timer);
      this.timer = null;
    }
  },
  updateTime() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    this.currentTime = `${h}:${m}`;
  },

    onInit() {
      // 读取存储的常亮状态
      storage.get({
        key: 'keep_screen_on',
        success: (data) => {
          this.keepScreenOn = data === 'true';
          // 恢复之前的常亮设置
          brightness.setKeepScreenOn({
            keepScreenOn: this.keepScreenOn,
            fail: (err) => {
              console.log('恢复常亮状态失败:', err);
            }
          });
        },
        fail: () => {
          this.keepScreenOn = false;
        }
      });
    },

    goBack() {
      router.back();
    },

    // ====== 屏幕常亮开关 ======
    onKeepScreenOnChange(e) {
      const newState = e.checked;
      this.keepScreenOn = newState;

      brightness.setKeepScreenOn({
        keepScreenOn: newState,
        success: () => {
          console.log('屏幕常亮设置成功:', newState);
          storage.set({
            key: 'keep_screen_on',
            value: String(newState),
            fail: (err) => {
              console.log('存储常亮状态失败:', err);
            }
          });
        },
        fail: (data, code) => {
          console.log('设置屏幕常亮失败:', data, code);
          prompt.showToast({
            message: '设置失败，请重试',
            duration: 1500
          });
          this.keepScreenOn = !newState;
        }
      });
    },

    // ====== 清除数据（双重确认） ======
    startClearConfirmation() {
      prompt.showDialog({
        title: '警告',
        message: '你确定要清除本地所有的统计和缓存吗？此操作不可回退！',
        buttons: [
          { text: '确认', color: '#ff3333' },
          { text: '取消', color: '#888888' }
        ],
        success: (data) => {
          if (data.index === 0) {
            prompt.showDialog({
              title: '二次核验确认',
              message: '再次确认：清空后所有熟知名单和7天统计图将归零。',
              buttons: [
                { text: '确认', color: '#ff3333' },
                { text: '取消', color: '#888888' }
              ],
              success: (secData) => {
                if (secData.index === 0) {
                  this.wipeAllPracticeRecords();
                }
              }
            });
          }
        }
      });
    },

    wipeAllPracticeRecords() {
      const allWipeKeys = ['vocab_familiar_words', 'vocab_global_stats', 'vocab_today_save'];
      let errorOccurred = false;
      let deleteCount = 0;

      allWipeKeys.forEach(k => {
        storage.delete({
          key: k,
          success: () => {
            deleteCount++;
            if (deleteCount === allWipeKeys.length && !errorOccurred) {
              prompt.showToast({ text: '清除完毕' });
            }
          },
          fail: () => {
            errorOccurred = true;
          }
        });
      });
    }
  }
</script>