  .color-kno { color: #aaaaaa; }
  .color-vag { color: #f1c40f; }
  .color-for { color: #e74c3c; }

  .action-grid {
    width: 100%;
    flex-direction: column;
  }
  .action-btn {
    width: 100%;
    height: 75px;
    justify-content: center;
    align-items: center;
    border-radius: 12px;
    margin-bottom: 12px;
  }
  .repeat-style {
    background-color: #1abc9c;
  }
  .home-style {
    background-color: #7f8c8d;
  }
  .action-btn-text {
    font-size: 24px;
    color: #ffffff;
    font-weight: bold;
  }
</style>

<script> //好了，下面是ai了
  import router from '@system.router';
  import storage from '@system.storage';
  import { words } from '../../common/words.js';

  const getStoreValue = (key) => new Promise((resolve) => {
    storage.get({ key, success: (d) => resolve(d ? JSON.parse(d) : null), fail: () => resolve(null) });
  });

  const setStoreValue = (key, val) => new Promise((resolve) => {
    storage.set({ key, value: JSON.stringify(val), success: () => resolve(true) });
  });

  const getLocalDate = () => {
    const d = new Date();
    const m = ('0' + (d.getMonth() + 1)).slice(-2);
    const date = ('0' + d.getDate()).slice(-2);
    return `${d.getFullYear()}-${m}-${date}`;
  };

  export default {
    private: {
      currentTime: '00:00', 
      timer: null,
      sessionWords: [],      
      activeIndices: [],
      isChineseVisible: false,
      isFinished: false,
      isRepeatMode: false,
      hasSavedStats: false,  
      totalWordsCount: 0,
      uniqueStudiedCount: 0,
      currentWord: { english: '', phonetic: '', chinese: '' },
      stats: { familiar: 0, know: 0, vague: 0, forgot: 0 }
    },

    async onInit() {
      const today = getLocalDate();
      const loadedSession = await getStoreValue('vocab_today_save');

      if (loadedSession && loadedSession.date === today) {
        this.sessionWords = loadedSession.words;
        this.activeIndices = loadedSession.activeIndices;
        this.isFinished = loadedSession.isFinished;
        this.hasSavedStats = loadedSession.hasSavedStats;
        this.stats = loadedSession.stats;
        this.isRepeatMode = loadedSession.isRepeatMode || false;
        this.totalWordsCount = this.sessionWords.length;
        this.updateUniqueStudied();
      } else {
        const userFamiliar = await getStoreValue('vocab_familiar_words') || [];
        
        // 使用原生的 Set 去重，把 O(N*M) 降为 O(N+M)
        const familiarSet = new Set(userFamiliar);
        const learnPool = words.filter(w => !familiarSet.has(w.english));

        if (learnPool.length === 0) {
          this.isFinished = true;
          this.totalWordsCount = 0;
          return;
        }

        const shuffled = this.shuffle([...learnPool]);
        const chosen = shuffled.slice(0, Math.min(50, shuffled.length));

        this.sessionWords = chosen.map(w => ({
          english: w.english,
          phonetic: w.phonetic,
          chinese: w.chinese,
          shownCount: 0,      
          targetCount: 1,     
          state: 'none',       
          firstState: 'none'  
        }));
        this.activeIndices = [];
        for (let i = 0; i < this.sessionWords.length; i++) {
          this.activeIndices.push(i);
        }

        this.isFinished = false;
        this.isRepeatMode = false;
        this.hasSavedStats = false;
        this.stats = { familiar: 0, know: 0, vague: 0, forgot: 0 };
        this.totalWordsCount = this.sessionWords.length;
        this.uniqueStudiedCount = 0;
        this.saveCurrentSession();
      }
      this.loadIndexWord();
      this.updateTime();
      
      // 定时器赋值
      this.timer = setInterval(() => {
        this.updateTime();
      }, 1000);
    },
    onDestroy() {
      if (this.timer) {
        clearInterval(this.timer);
        this.timer = null;
      }
    },

    updateTime() {
      const d = new Date();
      const h = ('0' + d.getHours()).slice(-2);
      const m = ('0' + d.getMinutes()).slice(-2);
      this.currentTime = `${h}:${m}`;
    },

    shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
      }
      return arr;
    },

    loadIndexWord() {
      if (this.activeIndices.length > 0) {
        const idx = this.activeIndices[0];
        this.currentWord = this.sessionWords[idx];
        this.isChineseVisible = false;
      } else {
        this.finishSession();
      }
    },

    toggleChinese() {
      this.isChineseVisible = !this.isChineseVisible;
    },

    updateUniqueStudied() {
      this.uniqueStudiedCount = this.sessionWords.filter(w => w.shownCount > 0).length;
    },

    async markWord(chosenState) {
      if (this.activeIndices.length === 0) return;
      const sessionIndex = this.activeIndices[0];
      const word = this.sessionWords[sessionIndex];

      word.shownCount++;
      word.state = chosenState;
      if (!this.isRepeatMode && word.firstState === 'none') {
        word.firstState = chosenState;
      }

      if (chosenState === 'familiar' && !this.isRepeatMode) {
        await this.addGlobalFamiliar(word.english);
      }

      if (chosenState === 'familiar') {
        word.targetCount = word.shownCount;
      } else if (chosenState === 'know') {
        word.targetCount = 3;
      } else if (chosenState === 'vague') {
        word.targetCount = 5;
      } else if (chosenState === 'forgot') {
        word.targetCount = 7;
      }

      this.activeIndices.shift();
      if (word.shownCount < word.targetCount && chosenState !== 'familiar') {
        this.activeIndices.push(sessionIndex);
      }

      this.updateUniqueStudied();
      this.saveCurrentSession();
      if (this.activeIndices.length === 0) {
        this.finishSession();
      } else {
        this.loadIndexWord();
      }
    },

    async addGlobalFamiliar(engWord) {
      const famList = await getStoreValue('vocab_familiar_words') || [];
      if (!famList.includes(engWord)) {
        famList.push(engWord);
        await setStoreValue('vocab_familiar_words', famList);
      }
    },

    endTodayPractice() {
      this.finishSession();
    },

    finishSession() {
      this.isFinished = true;
      if (!this.isRepeatMode && !this.hasSavedStats) {
        let statsFam = 0, statsKno = 0, statsVag = 0, statsFor = 0;
        this.sessionWords.forEach(w => {
          if (w.shownCount > 0) {
            if (w.firstState === 'familiar') statsFam++;
            else if (w.firstState === 'know') statsKno++;
            else if (w.firstState === 'vague') statsVag++;
            else if (w.firstState === 'forgot') statsFor++;
          }
        });
        this.stats = { familiar: statsFam, know: statsKno, vague: statsVag, forgot: statsFor };
        this.archiveFirstStudyToHistory();
        this.hasSavedStats = true;
      }
      this.saveCurrentSession();
    },

    async archiveFirstStudyToHistory() {
      const statsMap = await getStoreValue('vocab_global_stats') || {};
      const todayKey = getLocalDate();
      statsMap[todayKey] = this.stats;
      await setStoreValue('vocab_global_stats', statsMap);
    },

    saveCurrentSession() {
      setStoreValue('vocab_today_save', {
        date: getLocalDate(),
        words: this.sessionWords,
        activeIndices: this.activeIndices,
        isFinished: this.isFinished,
        hasSavedStats: this.hasSavedStats,
        stats: this.stats,
        isRepeatMode: this.isRepeatMode,
        totalWordsCount: this.totalWordsCount
      });
    },

    startRepeatPractice() {
      this.isRepeatMode = true;
      this.sessionWords.forEach(w => {
        w.shownCount = 0;
        w.targetCount = 1;
        w.state = 'none';
      });
      this.activeIndices = [];
      for (let i = 0; i < this.sessionWords.length; i++) {
        this.activeIndices.push(i);
      }

      this.isFinished = false;
      this.uniqueStudiedCount = 0;
      this.saveCurrentSession();
      this.loadIndexWord();
    },

    goHome() {
      router.back();
    }
  }
</script>