<template>
  <scroll scroll-y="true" class="page-scroll">
    <div class="container">
      
      <div class="header">
        <text class="back-btn" @click="goHome"> 返回 </text>
        <text class="header-time">{{ currentTime }}</text>
        <text class="title">今日单词</text>
      </div>

      <div class="learn-region" if="{{!isFinished}}">
        
        <div class="progress-bar">
          <text class="progress-txt">待清数: {{activeIndices.length}} 个</text>
          <text class="progress-txt">已学: {{uniqueStudiedCount}}/{{totalWordsCount}}</text>
        </div>

        <div class="word-card">
          <text class="eng">{{currentWord.english}}</text>
          <text class="phonetic">{{currentWord.phonetic}}</text>
          
          <div class="chinese-zone" @click="toggleChinese">
            <text class="chinese-text" if="{{isChineseVisible}}">{{currentWord.chinese}}</text>
            <text class="chinese-btn-text" else>点击显示中文释义</text>
          </div>
        </div>

        <div class="buttons-grid">
          <div class="option-btn familiar-color" @click="markWord('familiar')">
            <text class="option-txt">熟知</text>
          </div>
          <div class="option-btn know-color" @click="markWord('know')">
            <text class="option-txt-dark">认识</text>
          </div>
          <div class="option-btn vague-color" @click="markWord('vague')">
            <text class="option-txt-dark">模糊</text>
          </div>
          <div class="option-btn forgot-color" @click="markWord('forgot')">
            <text class="option-txt">忘记</text>
          </div>
        </div>

        <div class="btn-quit" @click="endTodayPractice">
          <text class="btn-quit-text">结束今日练习</text>
        </div>
      </div>

      <div class="end-region" else>
        <div class="complete-header">
          <text class="zhufu">恭喜</text>
          <text class="complete-label">今日修行已结束</text>
          <text class="complete-sub">{{isRepeatMode ? '【当前为复习测试模式】' : '完成今日背诵进度'}}</text>
        </div>

        <div class="report-box">
          <text class="report-row">学习单词数: {{uniqueStudiedCount}} 个</text>
          <text class="report-row color-fam">熟记: {{stats.familiar}}</text>
          <text class="report-row color-kno">认识: {{stats.know}}</text>
          <text class="report-row color-vag">模糊: {{stats.vague}}</text>
          <text class="report-row color-for">忘记: {{stats.forgot}}</text>
        </div>

        <div class="action-grid">
          <div class="action-btn repeat-style" @click="startRepeatPractice">
            <text class="action-btn-text">重复练习</text>
          </div>
          <div class="action-btn home-style" @click="goHome">
            <text class="action-btn-text">回到首页</text>
          </div>
        </div>
      </div>

    </div>
  </scroll>
</template>

<style>
